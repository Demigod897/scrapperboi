# Database
# Use "db" for Docker, "localhost" for running outside Docker
DATABASE_URL=postgresql+asyncpg://scrapperboi:scrapperboi@db:5432/scrapperboi
DATABASE_URL_SYNC=postgresql://scrapperboi:scrapperboi@db:5432/scrapperboi

# Redis
# Use "redis" for Docker, "localhost" for running outside Docker
REDIS_URL=redis://redis:6379/0

# Meilisearch
# Use "meilisearch" for Docker, "localhost" for running outside Docker
MEILI_URL=http://meilisearch:7700
MEILI_MASTER_KEY=scrapperboi-dev-key

# MinIO / S3
# Use "minio" for Docker, "localhost" for running outside Docker
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=scrapperboi-raw
MINIO_SECURE=false

# Google Cloud Vision (Tier 2 OCR -- optional)
GOOGLE_APPLICATION_CREDENTIALS=

# App
APP_ENV=development
APP_SECRET_KEY=change-me-in-production
LOG_LEVEL=INFO

# Scraping
SCRAPE_USER_AGENT=Mozilla/5.0 (compatible; ScrapperBoi/1.0; +https://scrapperboi.in/bot; regulatory-research)
SCRAPE_DEFAULT_MIN_DELAY=2.0
SCRAPE_DEFAULT_MAX_DELAY=5.0
